{
  "name": "tia",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx apps/api/src/server.ts",
    "start": "node apps/api/dist/server.cjs",
    "build": "vite build --config apps/web/vite.config.ts && tsx apps/api/build.ts",
    "preview": "vite preview --config apps/web/vite.config.ts",
    "clean": "node -e \"const fs=require('fs');['apps/api/dist','apps/web/dist'].forEach((target)=>fs.rmSync(target,{recursive:true,force:true}))\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.0.0",
    "react-joyride": "^2.9.3",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
