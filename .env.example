# GEMINI_API_KEY: Optional.
# Used only by the current Gemini-based assistant inherited from the AI Studio prototype.
# The project is not permanently tied to Gemini as its final AI provider.
GEMINI_API_KEY=""

# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET:
# Required only if you want to use Google Calendar OAuth locally.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# APP_URL:
# Base URL where the app is running. Used for OAuth callbacks.
# Example: http://localhost:3000
APP_URL="http://localhost:3000"
