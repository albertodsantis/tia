# DATABASE_URL: Required.
# PostgreSQL connection string.
# Example: postgresql://postgres:dev@localhost:5432/efi
DATABASE_URL=""

# SESSION_SECRET: Required.
# A long random string used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=""

# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET: Required.
# Google OAuth credentials for Calendar integration.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# APP_URL: Required.
# Base URL where the app is running. Used for OAuth callbacks.
APP_URL="http://localhost:3000"

# PORT: Optional. Defaults to 3000.
PORT=3000

# NODE_ENV: Optional. Defaults to 'development'.
NODE_ENV="development"

# GEMINI_API_KEY: Optional.
# Used for the experimental AI assistant feature.
GEMINI_API_KEY=""

# SUPABASE_URL: Required.
# Found in Supabase Dashboard > Settings > API.
SUPABASE_URL=""

# SUPABASE_ANON_KEY: Required.
# Public anon key. Found in Supabase Dashboard > Settings > API > anon public.
# Safe to expose in frontend — used for Google OAuth flow.
SUPABASE_ANON_KEY=""

# SUPABASE_SERVICE_KEY: Required.
# Use the "service_role" key (NOT the anon key).
# Found in Supabase Dashboard > Settings > API > service_role.
SUPABASE_SERVICE_KEY=""

# SENTRY_DSN: Optional but recommended in production.
# Backend error tracking. Get from Sentry → efi-backend project settings.
SENTRY_DSN=""

# VITE_SENTRY_DSN: Optional but recommended in production.
# Frontend error tracking. Get from Sentry → efi-frontend project settings.
# Must be prefixed with VITE_ to be exposed to the browser bundle.
VITE_SENTRY_DSN=""

# ADMIN_API_KEY: Optional. Enables /api/admin/stats when set.
# Use a long random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=""

# AI_UNLIMITED_EMAILS: Optional. Comma-separated list of emails that bypass the
# Efi IA monthly quota. Usage is still tracked, but the limit is never enforced.
AI_UNLIMITED_EMAILS=""
